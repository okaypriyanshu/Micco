# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Access control (recommended)
# Admin: only these user IDs can /upload, /stock, and use the bot in DM (comma-separated)
ADMIN_IDS=123456789

# Only these group/supergroup chat IDs can use the bot (comma-separated; get ID by adding @RawDataBot to the group)
ALLOWED_GROUP_IDS=-1001234567890,-1009876543210

# Only these user IDs can use the bot in groups (comma-separated). If empty, everyone in allowed groups can use.
ALLOWED_USER_IDS=111222333,444555666
